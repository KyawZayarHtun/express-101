# ==============================================================================
# APP CONFIGURATION
# ==============================================================================
NODE_ENV=development
PORT=3000
APP_NAME="Express API"
APP_URL=http://localhost:3000

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# Examples for popular databases. Uncomment and use the one you need.

# PostgreSQL / MySQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=root
DB_PASSWORD=your_secure_password
DB_NAME=my_express_db

# MongoDB (Mongoose) Connection URI
DATABASE_URL=mongodb://localhost:27017/my_express_db

# Redis Configuration (Caching/Sessions)
REDIS_URL=redis://localhost:6379

# ==============================================================================
# SECURITY & AUTHENTICATION
# ==============================================================================
# Generate a secure string (e.g., using `openssl rand -base64 32`)
JWT_SECRET=your_jwt_secret_key_dont_share
JWT_EXPIRES_IN=7d

# Session secret (if using express-session)
SESSION_SECRET=your_express_session_secret

# CORS Allowed Origins (Comma-separated list)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ==============================================================================
# THIRD-PARTY SERVICES & APIS (Examples)
# ==============================================================================
# Email Service (e.g., Nodemailer, SendGrid)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@yourdomain.com

# Payment Gateway (e.g., Stripe)
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Cloud Storage (e.g., AWS S3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your_s3_bucket_name
